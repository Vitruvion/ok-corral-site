# Instagram (server-side; see docs/instagram-setup.md to obtain).
# Long-lived token, expires in 60 days, must be refreshed before expiry.
# If unset, the InstagramStrip section renders a CTA pointing to the profile.
INSTAGRAM_ACCESS_TOKEN=

# Stripe — TEST mode keys. Switch to live (pk_live_/sk_live_) before launch.
# Used by /api/checkout for both gift card and merch orders.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx

# Resend — for booking inquiry email notifications.
# When RESEND_API_KEY is unset, /api/booking-notify silently no-ops; the form
# submission still writes to Supabase. Get a key at https://resend.com.
RESEND_API_KEY=
RESEND_FROM_EMAIL=howdy@okcorralsaloon.com
RESEND_TO_EMAIL=howdy@okcorralsaloon.com
